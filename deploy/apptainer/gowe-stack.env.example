# =============================================================================
# GoWe Apptainer Stack Configuration
# =============================================================================
#
# Copy this file to gowe-stack.env and customise for your environment.
#
#   cp gowe-stack.env.example gowe-stack.env
#
# All values below are defaults — override only what you need.
# =============================================================================

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Directory containing the built SIF images.
SIF_DIR=/opt/gowe/sif

# Root directory for all persistent data (DB, Shock nodes, MongoDB).
DATA_DIR=/data/gowe

# ---------------------------------------------------------------------------
# Instance naming
# ---------------------------------------------------------------------------

# Prefix for Apptainer instance names.
# Useful when multiple stacks run on the same host.
INSTANCE_PREFIX=gowe

# ---------------------------------------------------------------------------
# Port configuration
# ---------------------------------------------------------------------------

# All services use host networking (Apptainer default).
MONGO_PORT=27017
SHOCK_PORT=7445
SERVER_PORT=8080

# ---------------------------------------------------------------------------
# GoWe Server
# ---------------------------------------------------------------------------

# Executor used when no hint is given (local | container | worker | apptainer).
GOWE_DEFAULT_EXECUTOR=worker

# Allow unauthenticated access (set to true only for trusted networks).
GOWE_ALLOW_ANONYMOUS=false

# Executors available to anonymous users.
GOWE_ANONYMOUS_EXECUTORS=local,docker,worker,container,apptainer

# Logging
GOWE_LOG_LEVEL=info

# Scheduler poll interval (lower = more responsive, higher = less CPU).
GOWE_SCHEDULER_POLL=2s

# ---------------------------------------------------------------------------
# Shock (file storage backend)
# ---------------------------------------------------------------------------

# Shock server host (override for external Shock in --server-only mode).
# Defaults to localhost:$SHOCK_PORT when running the full stack.
SHOCK_HOST=localhost:7445

# Authentication token for Shock uploads (leave empty for anonymous).
SHOCK_TOKEN=

# Use HTTP instead of HTTPS for Shock connections.
SHOCK_USE_HTTP=true

# ---------------------------------------------------------------------------
# Worker configuration
# ---------------------------------------------------------------------------

# GoWe server URL (from the worker's perspective).
GOWE_SERVER_URL=http://localhost:8080

# Worker identity (defaults to hostname if empty).
GOWE_WORKER_NAME=

# Worker group for scheduling affinity.
GOWE_WORKER_GROUP=default

# Container runtime for executing CWL tools: apptainer | docker | none.
GOWE_RUNTIME=apptainer

# Scratch directory for task execution.
GOWE_WORKDIR=/tmp/gowe-worker

# Shock host for file staging (from the worker's perspective).
GOWE_SHOCK_HOST=localhost:7445

# Staging mode: copy | symlink | reference.
GOWE_STAGE_MODE=copy

# Server polling interval.
GOWE_POLL=5s

# Worker authentication key (must match a key in the server's --worker-keys file).
GOWE_WORKER_KEY=

# Path to pre-built worker binary.
GOWE_WORKER_BINARY=/opt/gowe/bin/worker

# ---------------------------------------------------------------------------
# GPU support
# ---------------------------------------------------------------------------

# Enable NVIDIA GPU passthrough (adds --nv to apptainer exec).
GOWE_GPU=false

# Restrict to specific GPU device(s) (comma-separated, e.g. "0" or "0,1").
GOWE_GPU_ID=

# ---------------------------------------------------------------------------
# Debug
# ---------------------------------------------------------------------------

# Set to true for debug-level logging on workers.
GOWE_DEBUG=false
