# GoWe Environment Configuration
# ================================
# Copy this file to .env and customize for your environment.
# The .env file is gitignored and will not be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env  # or use: set -a; source .env; set +a
#
# Or use the setup script:
#   ./scripts/setup-env.sh

# =============================================================================
# Server Configuration
# =============================================================================

# Server listen address (default: :8080)
GOWE_ADDR=:8080

# Database path (default: ~/.gowe/gowe.db, use ":memory:" for testing)
GOWE_DB_PATH=

# Log level: debug, info, warn, error (default: info)
GOWE_LOG_LEVEL=info

# Default executor: local, docker, worker, or empty for hint-based
GOWE_DEFAULT_EXECUTOR=

# =============================================================================
# Worker Configuration
# =============================================================================

# Server URL for worker to connect to
GOWE_SERVER_URL=http://localhost:8080

# Worker name (default: hostname)
GOWE_WORKER_NAME=

# Worker group for task scheduling
GOWE_WORKER_GROUP=default

# Container runtime: docker, apptainer, none/bare
GOWE_WORKER_RUNTIME=docker

# Worker working directory (default: $TMPDIR/gowe-worker)
GOWE_WORKER_WORKDIR=

# Worker poll interval (default: 5s)
GOWE_WORKER_POLL=5s

# Output staging mode: local, file:///path, s3://bucket, shock://host
GOWE_STAGE_OUT=local

# =============================================================================
# Path Mappings (for distributed/Docker-in-Docker)
# =============================================================================

# Docker-in-Docker path mapping: container_path=host_path:container2=host2
# Required when worker runs in container but spawns sibling containers
# Example: /workdir=/home/user/gowe/tmp/workdir:/testdata=/home/user/gowe/testdata
DOCKER_HOST_PATH_MAP=

# Input path mapping: translates paths in task inputs
# Example: /server/path=/worker/path
INPUT_PATH_MAP=

# CLI path mapping for gowe run command
# Maps local paths to paths inside worker containers
GOWE_PATH_MAP=

# =============================================================================
# Test Environment Paths
# =============================================================================

# Project root (auto-detected if not set)
GOWE_PROJECT_ROOT=

# Test data directory
GOWE_TESTDATA=

# Shared working directory for distributed tests
GOWE_WORKDIR=

# Conformance test directory
GOWE_CONFORMANCE_DIR=

# =============================================================================
# Test Ports (to avoid conflicts)
# =============================================================================

# Server port for server-local tests (default: 8091)
GOWE_TEST_SERVER_LOCAL_PORT=8091

# Server port for distributed tests (default: 8090)
GOWE_TEST_DISTRIBUTED_PORT=8090

# =============================================================================
# S3 / MinIO Configuration
# =============================================================================

# S3-compatible endpoint (leave empty for AWS S3)
S3_ENDPOINT=localhost:9000

# AWS/S3 credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 region (default: us-east-1)
AWS_REGION=us-east-1

# Default bucket for staging
S3_BUCKET=gowe-staging

# Use path-style addressing (required for MinIO)
S3_PATH_STYLE=true

# Disable SSL (for local MinIO)
S3_DISABLE_SSL=true

# =============================================================================
# Shock Configuration
# =============================================================================

# Default Shock server host
SHOCK_HOST=

# Shock authentication token
SHOCK_TOKEN=

# Use HTTP instead of HTTPS (for local development)
SHOCK_USE_HTTP=false

# =============================================================================
# BV-BRC Configuration
# =============================================================================

# BV-BRC authentication token (from 'gowe login' or manual)
BVBRC_TOKEN=

# =============================================================================
# Docker Configuration
# =============================================================================

# Docker socket path (default: /var/run/docker.sock)
DOCKER_HOST=

# =============================================================================
# CI/Testing Flags
# =============================================================================

# Skip Docker-dependent tests
GOWE_NO_DOCKER=false

# Run only required conformance tests (84 tests vs 378)
GOWE_QUICK_TESTS=false

# Verbose test output
GOWE_VERBOSE=false
